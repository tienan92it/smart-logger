# ===========================================
# Smart Logger Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# Jira Configuration
# -------------------------------------------
JIRA_SERVER=https://your-company.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your-jira-api-token

# -------------------------------------------
# Gemini AI (for natural language parsing)
# -------------------------------------------
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# -------------------------------------------
# Notion Configuration
# -------------------------------------------
# Optional: Pre-fill email on Notion login
NOTION_EMAIL=your@email.com

# Form IDs (get from browser DevTools when submitting form)
NOTION_FORM_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_SPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -------------------------------------------
# Notion Project Mapping
# -------------------------------------------
# Map project names to Notion page IDs (for the Project relation field)
# 
# Option 1: JSON mapping (recommended for multiple projects)
# NOTION_PROJECTS={"DF": "page-id-1", "HF": "page-id-2"}
#
# Option 2: Individual environment variables
NOTION_PROJECT_DF=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_PROJECT_HF=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Default project name when -p flag is not provided
NOTION_PROJECT_DEFAULT_NAME=DF

# -------------------------------------------
# Notion Form Property IDs (Optional)
# -------------------------------------------
# Only change these if your form has different property IDs
# NOTION_PROP_ID_PROJECT=cjkf
# NOTION_PROP_ID_PROOF=SJfi
# NOTION_PROP_ID_TIME=RUz\
# NOTION_PROP_ID_TYPE=ZA~q
# NOTION_PROP_ID_DATE=joDR
